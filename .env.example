# Contentful — à remplir dans un fichier .env local (gitignoré).
# La Delivery API (ACCESS_TOKEN) reste exposée côté client — read-only, pattern Contentful standard.
# La Management API (CMA_TOKEN) n'est utilisée que côté serveur (Netlify Functions) — JAMAIS dans le JS client.
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_CMA_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Auth admin — JWT signé côté serveur. Le mot de passe n'est jamais stocké en clair, uniquement son hash bcrypt.
# Générer le hash avec : node scripts/hash-password.js "mon-mot-de-passe"
ADMIN_ID=
ADMIN_PASSWORD_HASH=
JWT_SECRET=
JWT_TTL_MINUTES=30
